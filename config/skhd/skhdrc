# Focus movement
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# Swap windows
shift + alt - h : yabai -m window --swap west
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - l : yabai -m window --swap east

# Smart window resizing
ctrl + alt - h : yabai -m window --resize left:-40:0 || yabai -m window --resize right:-40:0
ctrl + alt - l : yabai -m window --resize right:40:0 || yabai -m window --resize left:40:0
ctrl + alt - k : yabai -m window --resize top:0:-40 || yabai -m window --resize bottom:0:-40
ctrl + alt - j : yabai -m window --resize bottom:0:40 || yabai -m window --resize top:0:40

# Balance and equalize
alt - e : yabai -m space --balance

# Float and center
alt - f : yabai -m window --toggle float
alt - c : yabai -m window --grid 4:4:1:1:2:2

# Move windows between spaces
shift + alt - 1 : yabai -m window --space 1
shift + alt - 2 : yabai -m window --space 2
shift + alt - 3 : yabai -m window --space 3
shift + alt - 4 : yabai -m window --space 4

# Focus spaces
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4

# Restart services quickly
shift + alt - r : yabai --restart-service; skhd --restart-service

# Flip space layout
shift + alt - y : yabai -m space --mirror y-axis
shift + alt - x : yabai -m space --mirror x-axis

# Stack management
alt - s : yabai -m window --stack prev
alt - d : yabai -m window --warp east
alt - tab : yabai -m window --focus stack.next || yabai -m window --focus stack.first
shift + alt - tab : yabai -m window --focus stack.prev || yabai -m window --focus stack.last

# Layout toggles
alt - t : yabai -m space --layout float
shift + alt - t : yabai -m space --layout bsp
alt - z : yabai -m window --toggle zoom-fullscreen
shift + alt - f : yabai -m window --toggle zoom-parent

# Utility launcher
alt - x : open -a "Calculator"
cmd - e : osascript -e 'tell application "Finder" to make new Finder window' -e 'tell application "Finder" to activate'
